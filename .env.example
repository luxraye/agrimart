# ── Supabase (required) ───────────────────────────────────────────────────────
# Create a project at https://supabase.com, run supabase/schema.sql, then fill these in.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── WhatsApp Cloud API (farmer channel) ───────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=          # random string — must match the value set in Meta webhook config
WHATSAPP_ACCESS_TOKEN=          # Meta app permanent/temporary access token
WHATSAPP_PHONE_NUMBER_ID=       # Meta WhatsApp phone number ID (not the phone number itself)
WHATSAPP_APP_SECRET=            # Meta app secret — validates X-Hub-Signature-256 on inbound posts
NEXT_PUBLIC_WHATSAPP_NUMBER=    # optional — display number shown on the Profile link card, e.g. +267 71 234 567

# ── Data pipeline ─────────────────────────────────────────────────────────────
CRON_SECRET=                    # random string — authenticates Vercel cron calls
ADMIN_SECRET=                   # password for /admin ops console
MODIS_API_KEY=                  # optional — NASA EarthData key for MODIS NDVI
FAOSTAT_API_TOKEN=              # optional — FAOSTAT account token if legacy host is down
